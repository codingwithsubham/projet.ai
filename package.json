{
  "name": "express-boilerplate",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server",
    "server": "nodemon server",
    "app": "npm start --prefix app",
    "dev": "concurrently \"npm run server\" \"npm run app\"",
    "build": "npm install --legacy-peer-deps && npm install --prefix app && npm run build --prefix app",
    "setup:local": "npm install && npm install --prefix app"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.14",
    "@langchain/community": "^1.1.20",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.11",
    "@langchain/pinecone": "^1.0.1",
    "@langchain/textsplitters": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "ignore": "^7.0.5",
    "langchain": "^1.2.28",
    "langsmith": "^0.5.4",
    "mongoose": "^9.2.1",
    "multer": "^2.1.0",
    "nodemon": "^3.1.11",
    "openai": "^6.25.0",
    "zod": "^4.3.6"
  }
}
